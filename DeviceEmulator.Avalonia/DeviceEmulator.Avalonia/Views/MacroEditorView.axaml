<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:DeviceEmulator.ViewModels"
             xmlns:models="clr-namespace:DeviceEmulator.Models"
             xmlns:converters="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="DeviceEmulator.Views.MacroEditorView"
             x:DataType="viewModels:DeviceTreeItemViewModel">
    
    <UserControl.DataTemplates>
        <DataTemplate DataType="models:MacroStep">
            <StackPanel>
                <!-- Compact single-row step card -->
                <Border Background="{Binding IsSelected, Converter={x:Static converters:ObjectConverters.IsNotNull}, FallbackValue=#1E1E1E}" 
                        CornerRadius="4" Margin="0,1,0,1" Padding="0" 
                        BorderThickness="1" BorderBrush="#333333"
                        Tapped="OnStepTapped" Cursor="Hand"
                        ToolTip.Tip="{Binding Summary}">
                    <Grid ColumnDefinitions="10,Auto,*,Auto" MinHeight="32">
                        <!-- Breakpoint indicator -->
                        <Border Grid.Column="0" CornerRadius="4,0,0,4">
                            <Panel>
                                <Ellipse Width="8" Height="8" Fill="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         IsVisible="{Binding !IsBreakpoint}"/>
                                <Ellipse Width="8" Height="8" Fill="#E51400" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         IsVisible="{Binding IsBreakpoint}"/>
                            </Panel>
                        </Border>
                        
                        <!-- Step type icon + badge -->
                        <Border Grid.Column="1" Padding="6,4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <!-- Type icon -->
                                <TextBlock FontSize="12" VerticalAlignment="Center"
                                           Foreground="{Binding StepType, Converter={x:Static converters:ObjectConverters.IsNotNull}, FallbackValue=#61AFEF}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="StepType"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Border CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2A4A6B"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding StepType}" FontSize="10" FontWeight="SemiBold" Foreground="#61AFEF"/>
                                </Border>
                                <!-- Executing badge -->
                                <Border Background="#4CAF50" CornerRadius="3" Padding="4,1" 
                                        IsVisible="{Binding IsExecuting}" VerticalAlignment="Center">
                                    <TextBlock Text="▶" FontSize="9" Foreground="White"/>
                                </Border>
                                <!-- Disabled indicator -->
                                <TextBlock Text="⊘" FontSize="11" Foreground="#666666" VerticalAlignment="Center"
                                           IsVisible="{Binding !IsEnabled}" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Summary text -->
                        <TextBlock Grid.Column="2" Text="{Binding Summary}" 
                                   VerticalAlignment="Center" Padding="4,0"
                                   FontSize="12" Foreground="#D4D4D4"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                        
                        <!-- Action buttons -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" Margin="4,0,6,0" VerticalAlignment="Center">
                            <Button Content="↑" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).MoveStepUp}" CommandParameter="{Binding}" Background="Transparent" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0"/>
                            <Button Content="↓" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).MoveStepDown}" CommandParameter="{Binding}" Background="Transparent" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0"/>
                            <Button Content="✕" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).RemoveStep}" CommandParameter="{Binding}" Background="Transparent" Foreground="#D32F2F" Padding="4,2" FontSize="10" MinWidth="0" MinHeight="0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Structural Children (If/While/For) -->
                <StackPanel IsVisible="{Binding IsStructuralStep}" Margin="0,2,0,2">
                    <Border BorderThickness="2,0,0,0" BorderBrush="#444444" Margin="14,0,0,0" Padding="14,0,0,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Children}" />
                            
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                <Button Content="➕ Code" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).AddCodeStep}" CommandParameter="{Binding}" FontSize="10" Classes="primary" Padding="6,3"/>
                                <Button Content="➕ Template" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).AddTemplateStep}" CommandParameter="{Binding}" FontSize="10" Classes="primary" Padding="6,3"/>
                                <Button Content="➕ If" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).AddIfStep}" CommandParameter="{Binding}" FontSize="10" Classes="primary" Padding="6,3"/>
                                <Button Content="➕ While" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).AddWhileStep}" CommandParameter="{Binding}" FontSize="10" Classes="primary" Padding="6,3"/>
                                <Button Content="➕ For" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).AddForStep}" CommandParameter="{Binding}" FontSize="10" Classes="primary" Padding="6,3"/>
                                <Button Content="📋 Paste Here" Command="{Binding $parent[UserControl].((viewModels:DeviceTreeItemViewModel)DataContext).PasteStep}" CommandParameter="{Binding}" FontSize="10" Classes="secondary" Padding="6,3" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>
    
    <Grid RowDefinitions="Auto,*">
        <!-- Toolbar -->
        <Border Background="#2D2D30" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="➕ Code" Command="{Binding AddCodeStep}" Classes="primary" FontSize="12"/>
                <Button Content="➕ Template" Command="{Binding AddTemplateStep}" Classes="primary" FontSize="12"/>
                <Button Content="➕ If" Command="{Binding AddIfStep}" Classes="primary" FontSize="12"/>
                <Button Content="➕ While" Command="{Binding AddWhileStep}" Classes="primary" FontSize="12"/>
                <Button Content="➕ For" Command="{Binding AddForStep}" Classes="primary" FontSize="12"/>
                <Button Content="📋 Paste" Command="{Binding PasteStep}" Classes="secondary" FontSize="12" Margin="10,0,0,0"/>
                <Button Content="⚙️ Manage Templates" Click="OnManageTemplates" Classes="secondary" FontSize="12" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Steps List -->
        <ScrollViewer Grid.Row="1" Margin="4">
            <ItemsControl ItemsSource="{Binding MacroSteps}" />
        </ScrollViewer>
    </Grid>
</UserControl>
